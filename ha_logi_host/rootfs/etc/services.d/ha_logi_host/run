#!/usr/bin/with-contenv bashio
# shellcheck shell=bash

bashio::log.info "Starting Logi Host Switch..."

# Debug: show hidraw device permissions
bashio::log.info "hidraw devices:"
for dev in /dev/hidraw*; do
    if [ -e "$dev" ]; then
        bashio::log.info "  $(ls -la "$dev")"
    fi
done
bashio::log.info "Running as: $(id)"

export MQTT_HOST="$(bashio::services mqtt 'host')"
export MQTT_PORT="$(bashio::services mqtt 'port')"
export MQTT_USER="$(bashio::services mqtt 'username')"
export MQTT_PASS="$(bashio::services mqtt 'password')"

export RECEIVER_TYPE="$(bashio::config 'receiver_type')"
export LOG_LEVEL="$(bashio::config 'log_level')"

# Optional: user-configured hidraw device path
if bashio::config.has_value 'device_path'; then
    export DEVICE_PATH="$(bashio::config 'device_path')"
    bashio::log.info "Using configured device path: ${DEVICE_PATH}"
else
    bashio::log.info "No device path configured — will auto-discover receiver"
fi

exec python3 -m logi_host
